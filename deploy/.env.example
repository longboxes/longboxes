# Longboxes — deployment configuration.
#
# Copy this file to `.env` in this same `deploy/` folder, set
# LIBRARY_PATH, then run:  docker compose up -d

# REQUIRED. Absolute host path to your comic library. Mounted
# read-only into the app — Longboxes never writes to your files.
LIBRARY_PATH=/path/to/your/comics

# Host port the web UI is served on — visit http://localhost:<WEB_PORT>/
WEB_PORT=8612

# Container timezone — affects log and UI timestamps.
TZ=UTC

# ── Optional ─────────────────────────────────────────────────────────
# Log verbosity: DEBUG / INFO / WARNING.
#LOG_LEVEL=INFO

# Set true ONLY when Longboxes is reached over HTTPS (e.g. behind a
# reverse proxy). On plain http it must stay false or login breaks.
#SESSION_COOKIE_SECURE=false

# Match-worker replicas. The match worker handles the heavy lane
# (match_file + volume_issues hydrations). More replicas mean lower
# per-call rate-limit wait times during a heavy initial import. The
# shared rate pacer keeps total ComicVine throughput inside the
# documented per-resource budgets, so this is a latency knob, not a
# total-speed knob. 1 is fine for small libraries; 3 is good for a
# fresh 10k+ file import. The non-match worker (browse + scan
# lanes) is a single instance — that work drains in seconds anyway.
#MATCH_WORKER_REPLICAS=1

# Note: the ComicVine API key is NOT configured here — you enter it in
# the admin UI after first launch. Database credentials and internal
# service URLs live in docker-compose.yml and never need touching.
