DATABASE_URL=postgresql+asyncpg://longboxes:longboxes@db:5432/longboxes
DATABASE_URL_SYNC=postgresql+psycopg://longboxes:longboxes@db:5432/longboxes
REDIS_URL=redis://redis:6379/0
APP_ENV=dev
LOG_LEVEL=INFO

# Host port to expose the web service on. Default 8612 (avoids common collisions on 8080).
WEB_PORT=8612

# Library mount — host path that gets bind-mounted read-only into the web and
# worker containers at /library. Leave unset to use the included empty-library
# placeholder (the scanner will simply find nothing).
LIBRARY_PATH=./.empty-library

# Seeds app_settings.library_paths on first boot. Comma-separated. Defaults to
# /library (matching the bind mount above). After the first boot, edits to
# library paths are made through the admin UI — this env is only the seed.
LIBRARY_PATHS=/library

# Match-worker replicas. The match worker drains the 'default' queue
# (match_file + volume_issues hydrations). More replicas mean lower
# per-call pacer wait times during a heavy import — the shared
# RedisRatePacer keeps total CV throughput capped, so this is about
# latency / queue concurrency, not absolute speed. 1 is fine for
# small libraries; 3 is a good number for a fresh 10k+ file import.
# The non-match worker (interactive + scan lanes) stays at 1 — it's
# light work and the lanes drain in seconds.
MATCH_WORKER_REPLICAS=1

# Sessions
SESSION_COOKIE_NAME=longboxes_session
SESSION_TTL_DAYS=30
# Set to true once you put the app behind HTTPS (browsers drop Secure cookies on http://).
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
